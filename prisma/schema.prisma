  isAttested         Boolean  @default(false)
  attestedBy         String?
  attestedAt         DateTime?

  organization       Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
}

model AttestationRecord {
  id              String   @id @default(cuid())
  organizationId  String
  linkId          String
  engineerName    String
  notes           String
  attestedAt      DateTime @default(now())

  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
}

model ValidationMilestone {
  id              String   @id @default(cuid())
  organizationId  String
  stageName       String
  status          String
  precisionPercent Float?
  startDate       DateTime
  signOffDate     DateTime?
  signedOffBy     String?

  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
}

model ConflictLog {
  id              String   @id @default(cuid())
  organizationId  String
  sourceRecordId  String
  conflictRecordId String
  description     String
  resolutionNotes String?
  resolvedBy      String?
  resolvedAt      DateTime?

  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
}

model DrawingProject {
  id            String   @id @default(cuid())
  name          String
  description   String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  ownerId       String
  
  owner         User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  drawings      Drawing[]
  comparisons   DrawingComparisonJob[]
  reports       DrawingReport[]

  @@index([ownerId])
}

model Drawing {
  id              String   @id @default(cuid())
  projectId       String
  name            String
  description     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  project         DrawingProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  revisions       DrawingRevision[]

  @@index([projectId])
}

model DrawingRevision {
  id              String   @id @default(cuid())
  drawingId       String
  revisionLabel   String
  fileUrl         String
  fileKey         String
  title           String?
  drawingNumber   String?
  material        String?
  dimensionsJson  String?
  notesJson       String?
  revHistoryJson  String?
  uploadedAt      DateTime @default(now())
  uploadedById    String

  drawing         Drawing  @relation(fields: [drawingId], references: [id], onDelete: Cascade)
  uploadedBy      User     @relation(fields: [uploadedById], references: [id], onDelete: Cascade)
  comparisonsAsA  DrawingComparisonJob[] @relation("RevA")
  comparisonsAsB  DrawingComparisonJob[] @relation("RevB")

  @@index([drawingId])
  @@index([uploadedById])
}

model DrawingComparisonJob {
  id              String   @id @default(cuid())
  projectId       String
  revAId          String
  revBId          String
  status          String
  error           String?
  progress        Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  project         DrawingProject   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  revA            DrawingRevision  @relation("RevA", fields: [revAId], references: [id], onDelete: Cascade)
  revB            DrawingRevision  @relation("RevB", fields: [revBId], references: [id], onDelete: Cascade)
  changes         DrawingDetectedChange[]

  @@index([projectId])
  @@index([revAId])
  @@index([revBId])
}

model DrawingDetectedChange {
  id                      String   @id @default(cuid())
  jobId                   String
  changeType              String
  actionType              String
  category                String
  description             String
  oldValue                String?
  newValue                String?
  boundingBox             String?
  manufacturingImpact     String?
  qualityImpact           String?
  createdAt               DateTime @default(now())

  job                     DrawingComparisonJob @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId])
}

model DrawingReport {
  id            String   @id @default(cuid())
  projectId     String
  title         String
  pdfUrl        String?
  summary       String
  changesJson   String
  mfgImpact     String
  qualityImpact String
  createdAt     DateTime @default(now())

  project       DrawingProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model SupplierRiskIndicator {
  id                    String      @id @default(cuid())
  supplierId            String
  geometryType          String      // "bore", "surface", "thread"
  onTimeRate            Float
  leadTimeDeviation     Int
  scrapRate             Float
  reworkRate            Float
  qualityTrend          String      // "improving", "stable", "degrading"
  predictor             Json?
  riskLevel             String      // HIGH, MEDIUM, LOW
  riskReason            String[]
  historicalMitigation  String[]
  successRate           Float
  confidenceScore       Float
  lastUpdated           DateTime    @updatedAt
  createdAt             DateTime    @default(now())

  supplier              Supplier    @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  @@index([supplierId])
}

model SupplierPredictedEvent {
  id                    String      @id @default(cuid())
  supplierId            String
  eventType             String      // "LEAD_TIME_SLIP", "QUALITY_ISSUE", "CAPACITY_CONSTRAINT"
  probability           Float
  expectedImpact        String
  historicalPrecedents  Int
  timeframe             String
  mitigationOptions     Json?
  createdAt             DateTime    @default(now())

  supplier              Supplier    @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  @@index([supplierId])
}

model EngineeringDecision {
  id                    String      @id @default(cuid())
  organizationId        String
  partId                String?
  supplierId            String?
  programId             String?
  decisionType          String      // TOLERANCE_CHANGE, MATERIAL_SUB, SUPPLIER_CHANGE, PROCESS_CHANGE
  description           String
  rationale             String
  proposedById          String
  proposedAt            DateTime    @default(now())
  status                String      // PROPOSED, APPROVED, IMPLEMENTED, COMPLETED, CLOSED
  outcome               String?     // SUCCESS, PARTIAL_SUCCESS, FAILURE
  outcomeDetails        String?
  costImpact            Float?
  scheduleImpact        Int?
  yieldImpact           Float?
  qualityMetrics        Json?
  lessonsLearned        String?
  reusableFor           String[]
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt
  closedAt              DateTime?

  proposedBy            User               @relation("DecisionProposer", fields: [proposedById], references: [id], onDelete: Cascade)
  supplier              Supplier?          @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  program               Program?           @relation(fields: [programId], references: [id], onDelete: SetNull)
  approvals             DecisionApproval[]
  milestones            DecisionMilestone[]

  @@index([organizationId])
  @@index([proposedById])
  @@index([supplierId])
  @@index([programId])
}

model DecisionApproval {
  id                    String              @id @default(cuid())
  decisionId            String
  approverId            String
  approvalType          String              // APPROVED, APPROVED_WITH_CONDITIONS, REJECTED, DEFERRED
  comment               String?
  conditions            String[]
  approvedAt            DateTime            @default(now())

  decision              EngineeringDecision @relation(fields: [decisionId], references: [id], onDelete: Cascade)
  approver              User                @relation(fields: [approverId], references: [id], onDelete: Cascade)

  @@index([decisionId])
  @@index([approverId])
}

model DecisionMilestone {
  id                    String              @id @default(cuid())
  decisionId            String
  milestoneType         String              // FIRST_ARTICLE, PRODUCTION, PROGRAM_DELIVERY, FIELD_OPERATION
  status                String              // PENDING, IN_PROGRESS, COMPLETE, FAILED
  actualOutcome         String?
  metrics               Json?
  completedAt           DateTime?
  createdAt             DateTime            @default(now())

  decision              EngineeringDecision @relation(fields: [decisionId], references: [id], onDelete: Cascade)

  @@index([decisionId])
}

model Program {
  id                    String              @id @default(cuid())
  organizationId        String
  name                  String              // "Boeing 787-MAX"
  aircraft              String              // "B787", "A350"
  budgetTarget          Float
  scheduleTarget        Int                 // days
  qualityTarget         Float               // acceptable NCR rate
  currentCost           Float?
  currentSchedule       Int?
  currentNCRRate        Float?
  currentScrapRate      Float?
  healthScore           Float               @default(100.0)
  costHealth            Float               @default(100.0)
  scheduleHealth        Float               @default(100.0)
  qualityHealth         Float               @default(100.0)
  riskAlerts            String[]
  startDate             DateTime            @default(now())
  targetCompletionDate  DateTime
  actualCompletionDate  DateTime?
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt

  organization          Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  decisions             EngineeringDecision[]
  predictions           ProgramPrediction[]

  @@index([organizationId])
}

model ProgramPrediction {
  id                    String              @id @default(cuid())
  programId             String
  predictionType        String              // SCHEDULE_SLIP, COST_OVERRUN, QUALITY_ISSUE
  probability           Float
  expectedImpact        String
  historicalPrecedents  Int
  timeframe             String
  recommendedAction     String
  createdAt             DateTime            @default(now())

  program               Program             @relation(fields: [programId], references: [id], onDelete: Cascade)

  @@index([programId])
}

model DrawingDesignPattern {
  id                    String              @id @default(cuid())
  organizationId        String
  drawingId             String?
  partType              String
  material              String
  geometryClass         String
  spanDimensions        String?
  toleranceClass        String?
  supplierName          String?
  yieldRate             Float               @default(95.0)
  costPerPart           Float
  rating                Float               @default(5.0)
  lessonsLearned        String
  relevanceTags         String[]
  createdAt             DateTime            @default(now())

  organization          Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
}

