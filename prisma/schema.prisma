generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id                 String               @id @default(cuid())
  email              String               @unique
  name               String?
  passwordHash       String?
  status             String               @default("active")
  lastLoginAt        DateTime?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  authEvents         AuthEvent[]
  members            OrganizationMember[]
  sessions           Session[]
  verificationTokens VerificationToken[]
}

model Organization {
  id                String               @id @default(cuid())
  name              String
  slug              String               @unique
  description       String?
  status            String               @default("active")
  ownerId           String?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  invitations       Invitation[]
  members           OrganizationMember[]
  precedents        Precedent[]
  precedentVersions PrecedentVersion[]
  roles             Role[]
  auditLogs         AuditLog[]
  reports           Report[]
  rules             Rule[]
  ruleFragments     RuleFragment[]
  ruleDependencies  RuleDependency[]
  ruleExecutionResults RuleExecutionResult[]
  contradictions    Contradiction[]
  orchestrationRuns OrchestrationRun[]
  realityAssessments RealityAssessment[]
  suppliers         Supplier[]
  supplierFacilities SupplierFacility[]
  supplierRelationships SupplierRelationship[]
  notifications     Notification[]
  ingestionDocuments IngestionDocument[]
  ingestionJobs     IngestionJob[]
  engineeringEntities EngineeringEntity[]
  engineeringRelationships EngineeringRelationship[]
  graphNodes        GraphNodeIndex[]
  graphEdges        GraphEdgeIndex[]
  graphLayouts      GraphLayout[]
  timestamps        Timestamp[]
}

model OrganizationMember {
  id             String       @id @default(cuid())
  organizationId String
  userId         String
  role           String       @default("engineer")
  status         String       @default("active")
  invitedBy      String?
  joinedAt       DateTime?
  createdAt      DateTime     @default(now())
  user           User         @relation(fields: [userId], references: [id])
  organization   Organization @relation(fields: [organizationId], references: [id])

  @@unique([organizationId, userId])
}

model Invitation {
  id             String       @id @default(cuid())
  organizationId String
  email          String
  userId         String?
  token          String       @unique
  role           String
  status         String       @default("pending")
  invitedBy      String?
  expiresAt      DateTime
  acceptedAt     DateTime?
  declinedAt     DateTime?
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id])
}

model Role {
  id             String       @id @default(cuid())
  organizationId String
  name           String
  slug           String?
  description    String?
  isSystem       Boolean      @default(true)
  permissions    String       @default("[]")
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id])

  @@unique([organizationId, name])
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  userAgent String?
  ipAddress String?
  isRevoked Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model VerificationToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  type      String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model AuthEvent {
  id        String   @id @default(cuid())
  userId    String
  action    String
  metadata  String   @default("{}")
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model AuditLog {
  id             String       @id @default(cuid())
  organizationId String
  action         String
  entity         String
  entityId       String
  metadata       String       @default("{}")
  createdById    String?
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
  @@index([organizationId, entity, entityId])
}

model EngineeringEntity {
  id                  String                    @id @default(cuid())
  organizationId      String
  entityType          String
  identifier          String
  name                String
  description         String?
  status              String                    @default("ACTIVE")
  version             String                    @default("1.0.0")
  metadata            String                    @default("{}")
  tags                String?
  labels              String?
  createdById         String?
  updatedById         String?
  deletedAt           DateTime?
  createdAt           DateTime                  @default(now())
  updatedAt           DateTime                  @updatedAt
  organization        Organization              @relation(fields: [organizationId], references: [id])
  targetRelationships EngineeringRelationship[] @relation("TargetEntity")
  sourceRelationships EngineeringRelationship[] @relation("SourceEntity")
  auditLogs           EntityAuditLog[]
  versions            EntityVersion[]
  results             RuleExecutionResult[]
  contradictionSource Contradiction[]           @relation("ContradictionSource")
  contradictionTarget Contradiction[]           @relation("ContradictionTarget")

  @@unique([organizationId, identifier])
  @@index([organizationId])
  @@index([organizationId, entityType])
  @@index([organizationId, status])
}

model EngineeringRelationship {
  id               String            @id @default(cuid())
  organizationId   String
  sourceEntityId   String
  targetEntityId   String
  relationshipType String
  metadata         String            @default("{}")
  createdById      String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  organization     Organization      @relation(fields: [organizationId], references: [id])
  targetEntity     EngineeringEntity @relation("TargetEntity", fields: [targetEntityId], references: [id])
  sourceEntity     EngineeringEntity @relation("SourceEntity", fields: [sourceEntityId], references: [id])

  @@unique([organizationId, sourceEntityId, targetEntityId, relationshipType])
  @@index([organizationId])
  @@index([organizationId, sourceEntityId])
  @@index([organizationId, targetEntityId])
}

model EntityVersion {
  id                String            @id @default(cuid())
  entityId          String
  version           String
  snapshot          String
  changeDescription String?
  createdById       String?
  createdAt         DateTime          @default(now())
  entity            EngineeringEntity @relation(fields: [entityId], references: [id])

  @@index([entityId])
  @@index([entityId, version])
}

model EntityAuditLog {
  id          String            @id @default(cuid())
  entityId    String
  action      String
  metadata    String            @default("{}")
  createdById String?
  createdAt   DateTime          @default(now())
  entity      EngineeringEntity @relation(fields: [entityId], references: [id])

  @@index([entityId])
  @@index([entityId, action])
}

model Rule {
  id             String       @id @default(cuid())
  organizationId String
  name           String
  description    String?
  category       String?
  priority       Int?
  severity       String?
  scope          String       @default("{}")
  condition      String       @default("{}")
  conditionRoot  String?
  action         String       @default("{}")
  status         String       @default("ACTIVE")
  version        String       @default("1.0.0")
  tags           String?
  labels         String?
  ownerId        String?
  createdById    String?
  updatedById    String?
  publishedAt    DateTime?
  publishedById  String?
  deletedAt      DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id])
  versions       RuleVersion[]
  dependencies   RuleDependency[] @relation("RuleDependencies")
  dependedOnBy   RuleDependency[] @relation("RuleDependedOn")
  executionResults RuleExecutionResult[]

  @@index([organizationId])
  @@index([organizationId, status])
  @@index([organizationId, name])
}

model RuleVersion {
  id                String   @id @default(cuid())
  ruleId            String
  version           String
  snapshot          String
  changeDescription String?
  createdById       String?
  createdAt         DateTime @default(now())
  rule              Rule     @relation(fields: [ruleId], references: [id])

  @@index([ruleId])
  @@index([ruleId, version])
}

model RuleFragment {
  id             String       @id @default(cuid())
  organizationId String
  name           String
  description    String?
  condition      String       @default("{}")
  createdById    String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id])

  @@unique([organizationId, name])
  @@index([organizationId])
}

model RuleDependency {
  id              String       @id @default(cuid())
  organizationId  String
  ruleId          String
  dependsOnRuleId String
  createdAt       DateTime     @default(now())
  organization    Organization @relation(fields: [organizationId], references: [id])
  rule            Rule         @relation("RuleDependencies", fields: [ruleId], references: [id])
  dependsOn       Rule         @relation("RuleDependedOn", fields: [dependsOnRuleId], references: [id])

  @@unique([organizationId, ruleId, dependsOnRuleId])
  @@index([organizationId])
  @@index([organizationId, ruleId])
  @@index([organizationId, dependsOnRuleId])
}

model RuleExecutionResult {
  id                     String            @id @default(cuid())
  organizationId         String
  ruleId                 String
  ruleVersion            String?
  subjectEntityId        String
  batchId                String?
  outcome                String
  trace                  String?
  supportingEntityIds    String            @default("[]")
  supportingDocumentRefs String            @default("[]")
  missingEvidence        String            @default("[]")
  conflictingEvidence    String            @default("[]")
  executionTimeMs        Int?
  triggeredById          String?
  createdAt              DateTime          @default(now())
  organization           Organization      @relation(fields: [organizationId], references: [id])
  rule                   Rule              @relation(fields: [ruleId], references: [id])
  subjectEntity          EngineeringEntity @relation(fields: [subjectEntityId], references: [id])

  @@index([organizationId])
  @@index([organizationId, ruleId])
  @@index([organizationId, subjectEntityId])
  @@index([organizationId, batchId])
}

model Contradiction {
  id               String                     @id @default(cuid())
  organizationId   String
  type             String
  severity         String                     @default("MEDIUM")
  sourceEntityId   String
  targetEntityId   String
  description      String
  status           String                     @default("OPEN")
  resolutionNotes  String?
  detectedById     String?
  resolvedById     String?
  detectedAt       DateTime                   @default(now())
  resolvedAt       DateTime?
  createdAt        DateTime                   @default(now())
  updatedAt        DateTime                   @updatedAt
  organization     Organization               @relation(fields: [organizationId], references: [id])
  sourceEntity     EngineeringEntity          @relation("ContradictionSource", fields: [sourceEntityId], references: [id])
  targetEntity     EngineeringEntity          @relation("ContradictionTarget", fields: [targetEntityId], references: [id])
  lifecycleLogs    ContradictionLifecycleLog[]

  @@index([organizationId])
  @@index([organizationId, status])
  @@index([organizationId, type])
  @@index([organizationId, sourceEntityId])
  @@index([organizationId, targetEntityId])
}

model ContradictionLifecycleLog {
  id              String        @id @default(cuid())
  contradictionId String
  action          String
  fromStatus      String?
  toStatus        String?
  changedById     String?
  notes           String?
  createdAt       DateTime      @default(now())
  contradiction   Contradiction @relation(fields: [contradictionId], references: [id])

  @@index([contradictionId])
}

model OrchestrationRun {
  id              String              @id @default(cuid())
  organizationId  String
  subjectEntityId String
  status          String              @default("QUEUED")
  outcome         String?
  triggeredById   String?
  inputs          String?
  currentStage    String?
  stageIndex      Int?
  cancelRequested Boolean             @default(false)
  startedAt       DateTime?
  completedAt     DateTime?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  organization    Organization        @relation(fields: [organizationId], references: [id])
  stageLogs       OrchestrationStageLog[]
  assessments     RealityAssessment[] @relation("RunAssessments")

  @@index([organizationId])
  @@index([organizationId, status])
  @@index([organizationId, subjectEntityId])
}

model OrchestrationStageLog {
  id           String           @id @default(cuid())
  runId        String
  stageName    String
  stageIndex   Int
  status       String
  attempt      Int              @default(1)
  startedAt    DateTime?
  completedAt  DateTime?
  durationMs   Int?
  errorMessage String?
  output       String?
  createdAt    DateTime         @default(now())
  run          OrchestrationRun @relation(fields: [runId], references: [id])

  @@index([runId])
  @@index([runId, stageName])
}

model RealityAssessment {
  id                String             @id @default(cuid())
  organizationId    String
  subjectEntityId   String
  orchestrationRunId String?
  status            String             @default("PENDING")
  outcome           String?
  triggeredById     String?
  currentStage      String?
  stageIndex        Int?
  cancelRequested   Boolean            @default(false)
  startedAt         DateTime?
  completedAt       DateTime?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  organization      Organization       @relation(fields: [organizationId], references: [id])
  orchestrationRun  OrchestrationRun?  @relation("RunAssessments", fields: [orchestrationRunId], references: [id])
  stageLogs         RealityStageLog[]

  @@index([organizationId])
  @@index([organizationId, status])
  @@index([organizationId, subjectEntityId])
}

model RealityStageLog {
  id           String           @id @default(cuid())
  assessmentId String
  stageName    String
  stageIndex   Int
  status       String
  attempt      Int              @default(1)
  startedAt    DateTime?
  completedAt  DateTime?
  durationMs   Int?
  errorMessage String?
  output       String?
  createdAt    DateTime         @default(now())
  assessment   RealityAssessment @relation(fields: [assessmentId], references: [id])

  @@index([assessmentId])
  @@index([assessmentId, stageName])
}

model Supplier {
  id                String       @id @default(cuid())
  organizationId    String
  supplierType      String?
  identifier        String
  name              String
  legalName         String?
  description       String?
  website           String?
  taxId             String?
  duns              String?
  cageCode          String?
  naicsCodes        String?
  industrySectors   String?
  supportedPrograms String?
  locations         String?
  riskNotes         String?
  engineeringNotes  String?
  status            String       @default("ACTIVE")
  tags              String?
  labels            String?
  metadata          String       @default("{}")
  createdById       String?
  updatedById       String?
  deletedAt         DateTime?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  organization      Organization @relation(fields: [organizationId], references: [id])
  contacts          SupplierContact[]
  facilities        SupplierFacility[]
  certifications    SupplierCertification[]
  capabilities      SupplierCapability[]
  sourceRelationships SupplierRelationship[] @relation("SourceSupplier")
  targetRelationships SupplierRelationship[] @relation("TargetSupplier")

  @@unique([organizationId, identifier])
  @@index([organizationId])
  @@index([organizationId, status])
  @@index([organizationId, name])
}

model SupplierContact {
  id          String   @id @default(cuid())
  supplierId  String
  name        String
  title       String?
  email       String?
  phone       String?
  mobile      String?
  role        String?
  isPrimary   Boolean  @default(false)
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  supplier    Supplier @relation(fields: [supplierId], references: [id])

  @@index([supplierId])
}

model SupplierFacility {
  id              String       @id @default(cuid())
  organizationId  String
  supplierId      String
  name            String
  type            String?
  address         String?
  city            String?
  state           String?
  country         String?
  postalCode      String?
  latitude        Float?
  longitude       Float?
  areaSqFt        Float?
  employees       Int?
  certifications  String?
  capabilities    String?
  status          String       @default("ACTIVE")
  metadata        String       @default("{}")
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  organization    Organization @relation(fields: [organizationId], references: [id])
  supplier        Supplier     @relation(fields: [supplierId], references: [id])

  @@index([organizationId])
  @@index([supplierId])
  @@index([organizationId, supplierId])
}

model SupplierCertification {
  id                  String   @id @default(cuid())
  supplierId          String
  certificationType   String?
  certificationName   String
  issuingBody         String?
  certificateNumber   String?
  issueDate           DateTime?
  expiryDate          DateTime?
  status              String   @default("ACTIVE")
  scope               String?
  evidenceUrl         String?
  evidenceDocumentId  String?
  notes               String?
  metadata            String   @default("{}")
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  supplier            Supplier @relation(fields: [supplierId], references: [id])

  @@index([supplierId])
}

model SupplierCapability {
  id               String   @id @default(cuid())
  supplierId       String
  capabilityType   String?
  capabilityName   String
  description      String?
  category         String?
  subcategory      String?
  materials        String?
  processes        String?
  equipment        String?
  qualityStandards String?
  maxDimensions    String?
  tolerances       String?
  capacity         String?
  leadTimeDays     Int?
  notes            String?
  status           String   @default("ACTIVE")
  metadata         String   @default("{}")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  supplier         Supplier @relation(fields: [supplierId], references: [id])

  @@index([supplierId])
}

model SupplierRelationship {
  id                  String       @id @default(cuid())
  organizationId      String
  sourceSupplierId    String
  targetSupplierId    String
  relationshipType    String
  description         String?
  contractReference   String?
  program             String?
  startDate           DateTime?
  endDate             DateTime?
  metadata            String       @default("{}")
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt
  organization        Organization @relation(fields: [organizationId], references: [id])
  sourceSupplier      Supplier     @relation("SourceSupplier", fields: [sourceSupplierId], references: [id])
  targetSupplier      Supplier     @relation("TargetSupplier", fields: [targetSupplierId], references: [id])

  @@unique([organizationId, sourceSupplierId, targetSupplierId, relationshipType])
  @@index([organizationId])
  @@index([sourceSupplierId])
  @@index([targetSupplierId])
}

model IngestionDocument {
  id              String                    @id @default(cuid())
  organizationId  String
  fileName        String
  mimeType        String?
  fileExtension   String?
  sizeBytes       Int?
  checksum        String?
  storageKey      String?
  currentVersion  Int                       @default(1)
  status          String                    @default("PENDING")
  uploadedById    String?
  deletedAt       DateTime?
  createdAt       DateTime                  @default(now())
  updatedAt       DateTime                  @updatedAt
  organization    Organization              @relation(fields: [organizationId], references: [id])
  versions        IngestionDocumentVersion[]
  jobs            IngestionJob[]

  @@index([organizationId])
  @@index([organizationId, status])
  @@index([organizationId, fileName])
}

model IngestionDocumentVersion {
  id              String             @id @default(cuid())
  documentId      String
  version         Int
  fileName        String?
  mimeType        String?
  sizeBytes       Int?
  checksum        String?
  storageKey      String?
  createdById     String?
  createdAt       DateTime           @default(now())
  document        IngestionDocument  @relation(fields: [documentId], references: [id])
  jobs            IngestionJob[]

  @@unique([documentId, version])
  @@index([documentId])
}

model IngestionJob {
  id                 String               @id @default(cuid())
  organizationId     String
  documentId         String
  documentVersionId  String?
  totalStages        Int?
  priority           Int                  @default(0)
  status             String               @default("QUEUED")
  currentStage       String?
  stageIndex         Int?
  progressPercent    Float?
  errorStage         String?
  errorMessage       String?
  cancelRequested    Boolean              @default(false)
  attempt            Int                  @default(1)
  startedAt          DateTime?
  completedAt        DateTime?
  scheduledAt        DateTime?
  createdById        String?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  organization       Organization         @relation(fields: [organizationId], references: [id])
  document           IngestionDocument    @relation(fields: [documentId], references: [id])
  documentVersion    IngestionDocumentVersion? @relation(fields: [documentVersionId], references: [id])
  stageLogs          IngestionStageLog[]
  validationIssues   IngestionValidationIssue[]
  extractedEntities  ExtractedEntity[]
  extractedRelationships ExtractedRelationship[]
  extractedReferences ExtractedReference[]

  @@index([organizationId])
  @@index([organizationId, status])
  @@index([documentId])
}

model IngestionStageLog {
  id           String       @id @default(cuid())
  jobId        String
  stageName    String
  stageIndex   Int
  status       String
  startedAt    DateTime?
  completedAt  DateTime?
  durationMs   Int?
  errorMessage String?
  createdAt    DateTime     @default(now())
  job          IngestionJob @relation(fields: [jobId], references: [id])

  @@index([jobId])
  @@index([jobId, stageName])
}

model IngestionValidationIssue {
  id       String       @id @default(cuid())
  jobId    String
  severity String
  code     String?
  message  String
  stage    String?
  context  String?
  job      IngestionJob @relation(fields: [jobId], references: [id])

  @@index([jobId])
}

model ExtractedEntity {
  id              String       @id @default(cuid())
  jobId           String
  organizationId  String?
  linkedEntityId  String?
  name            String
  entityType      String?
  identifier      String?
  description     String?
  confidence      Float?
  metadata        String       @default("{}")
  createdAt       DateTime     @default(now())
  job             IngestionJob @relation(fields: [jobId], references: [id])

  @@index([jobId])
  @@index([organizationId])
  @@index([linkedEntityId])
}

model ExtractedRelationship {
  id               String       @id @default(cuid())
  jobId            String
  sourceEntityId   String?
  targetEntityId   String?
  relationshipType String?
  confidence       Float?
  metadata         String       @default("{}")
  createdAt        DateTime     @default(now())
  job              IngestionJob @relation(fields: [jobId], references: [id])

  @@index([jobId])
}

model ExtractedReference {
  id        String       @id @default(cuid())
  jobId     String
  entityId  String?
  reference String
  type      String?
  context   String?
  confidence Float?
  metadata  String       @default("{}")
  createdAt DateTime     @default(now())
  job       IngestionJob @relation(fields: [jobId], references: [id])

  @@index([jobId])
}

model GraphNodeIndex {
  id             String       @id @default(cuid())
  organizationId String
  entityId       String
  entityType     String
  identifier     String
  name           String
  label          String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id])

  @@unique([organizationId, entityId])
  @@index([organizationId])
  @@index([organizationId, entityType])
}

model GraphEdgeIndex {
  id               String       @id @default(cuid())
  organizationId   String
  sourceEntityId   String
  targetEntityId   String
  relationshipType String
  createdAt        DateTime     @default(now())
  organization     Organization @relation(fields: [organizationId], references: [id])

  @@unique([organizationId, sourceEntityId, targetEntityId, relationshipType])
  @@index([organizationId])
  @@index([organizationId, sourceEntityId])
  @@index([organizationId, targetEntityId])
}

model GraphLayout {
  id             String           @id @default(cuid())
  organizationId String
  name           String
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  organization   Organization     @relation(fields: [organizationId], references: [id])
  nodes          GraphLayoutNode[]

  @@index([organizationId])
}

model GraphLayoutNode {
  id          String     @id @default(cuid())
  layoutId    String
  nodeIndexId String
  positionX   Float
  positionY   Float
  createdAt   DateTime   @default(now())
  layout      GraphLayout @relation(fields: [layoutId], references: [id])

  @@unique([layoutId, nodeIndexId])
  @@index([layoutId])
}

model Notification {
  id             String       @id @default(cuid())
  organizationId String
  userId         String
  type           String
  title          String
  message        String?
  link           String?
  metadata       String       @default("{}")
  isRead         Boolean      @default(false)
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId, userId])
  @@index([organizationId, userId, isRead])
}

model Report {
  id             String       @id @default(cuid())
  organizationId String
  type           String
  title          String
  filters        String       @default("{}")
  data           String       @default("{}")
  isFavorite     Boolean      @default(false)
  generatedById  String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
  @@index([organizationId, type])
}

model Precedent {
  id                    String             @id @default(cuid())
  organizationId        String
  title                 String
  summary               String?
  engineeringQuestion   String?
  decisionMade          String?
  supportingEvidence    String?            @default("[]")
  contradictions        String?            @default("[]")
  missingEvidence       String?            @default("[]")
  outcome               String?
  lessonsLearned        String?            @default("[]")
  relatedProjects       String?            @default("[]")
  relatedSuppliers      String?            @default("[]")
  relatedRequirements   String?            @default("[]")
  relatedDocuments      String?            @default("[]")
  relatedComponents     String?            @default("[]")
  relatedStandards      String?            @default("[]")
  relatedCertifications String?            @default("[]")
  decisionDate          DateTime?
  decisionOwner         String?
  confidence            Float?             @default(1.0)
  tags                  String?            @default("[]")
  organization          String?
  version               Int                @default(1)
  sourceEntityId        String?
  sourceAssessmentId    String?
  createdById           String?
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt
  deletedAt             DateTime?
  organizationRel       Organization       @relation(fields: [organizationId], references: [id])
  versions              PrecedentVersion[]

  @@index([organizationId])
  @@index([organizationId, title])
  @@index([organizationId, decisionDate])
  @@index([organizationId, decisionOwner])
  @@index([organizationId, confidence])
  @@index([organizationId, deletedAt])
}

model PrecedentVersion {
  id                String       @id @default(cuid())
  precedentId       String
  version           Int
  snapshot          String
  changeDescription String?
  createdById       String?
  createdAt         DateTime     @default(now())
  organizationId    String
  organizationRel   Organization @relation(fields: [organizationId], references: [id])
  precedent         Precedent    @relation(fields: [precedentId], references: [id])

  @@index([precedentId])
  @@index([precedentId, version])
}

model Timestamp {
  id        String       @id @default(cuid())
  label     String
  value     DateTime
  metadata  String       @default("{}")
  createdAt DateTime     @default(now())
  organizationId String?
  organization Organization? @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
}
