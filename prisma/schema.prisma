  relatedSuppliers      Json?     // Array of strings
  relatedRequirements   Json?     // Array of strings
  relatedDocuments      Json?     // Array of strings
  relatedComponents     Json?     // Array of strings
  relatedStandards      Json?     // Array of strings
  relatedCertifications Json?     // Array of strings
  decisionDate          DateTime                     @default(now())
